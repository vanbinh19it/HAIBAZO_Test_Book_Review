import { useSuspenseQuery } from "@tanstack/react-query"
import { createFileRoute } from "@tanstack/react-router"
import { Search } from "lucide-react"
import { Suspense } from "react"

import { AuthorsService } from "@/client"
import { DataTable } from "@/components/Common/DataTable"
import AddAuthor from "@/components/Authors/AddAuthor"
import { columns } from "@/components/Authors/columns"
import PendingAuthors from "@/components/Pending/PendingAuthors"

function getAuthorsQueryOptions() {
  return {
    queryFn: () => AuthorsService.readAuthors({ page: 1, pageSize: 100 }),
    queryKey: ["authors"],
  }
}

export const Route = createFileRoute("/_layout/authorsfdd/")({
  component: Authors,
  head: () => ({
    meta: [
      {
        title: "Authors - Haibazo Book Review",
      },
    ],
  }),
})

function AuthorsTableContent() {
  const { data: authors } = useSuspenseQuery(getAuthorsQueryOptions())

  if (authors.data.length === 0) {
    return (
      <div className="flex flex-col items-center justify-center text-center py-12">
        <div className="rounded-full bg-muted p-4 mb-4">
          <Search className="h-8 w-8 text-muted-foreground" />
        </div>
        <h3 className="text-lg font-semibold">You don't have any authors yet</h3>
        <p className="text-muted-foreground">Add a new author to get started</p>
      </div>
    )
  }

  return <DataTable columns={columns} data={authors.data} />
}

function AuthorsTable() {
  return (
    <Suspense fallback={<PendingAuthors />}>
      <AuthorsTableContent />
    </Suspense>
  )
}

function Authors() {
  return (
    <div className="flex flex-col gap-6">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-bold tracking-tight">Authors</h1>
          <p className="text-muted-foreground">Create and manage your authors</p>
        </div>
        <AddAuthor />
      </div>
      <AuthorsTable />
    </div>
  )
}
